// Brain Base — Prisma schema
// SQLite for local dev, Postgres in prod (swap provider via env)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────────
// Auth
// ───────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())

  accounts       Account[]
  sessions       Session[]
  notes          Note[]
  tags           Tag[]
  dailyLogs      DailyLog[]
  resources      Resource[]
  reviewCards    ReviewCard[]
  focusSessions  FocusSession[]
  uploads        Upload[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────────────────────────────────────────────
// Notes + Tags
// ───────────────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Untitled")
  content   String   @default("")
  starred   Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        NoteTag[]
  outgoing    NoteLink[] @relation("LinkSource")
  incoming    NoteLink[] @relation("LinkTarget")

  @@index([userId, updatedAt])
  @@index([userId, starred])
}

model Tag {
  id        String    @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime  @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes NoteTag[]

  @@unique([userId, name])
}

model NoteTag {
  noteId String
  tagId  String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

// Wikilinks between notes — drives the knowledge graph
model NoteLink {
  id       String @id @default(cuid())
  sourceId String
  targetId String

  source Note @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Note @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([targetId])
}

// ───────────────────────────────────────────────────────────────────────────
// Daily log
// ───────────────────────────────────────────────────────────────────────────

model DailyLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // truncated to UTC midnight
  content   String   @default("")
  mood      Int? // 0-100
  energy    Int? // 0-100
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ───────────────────────────────────────────────────────────────────────────
// Learning tracker
// ───────────────────────────────────────────────────────────────────────────

enum ResourceKind {
  READING
  COURSE
  WATCHING
}

enum ResourceStatus {
  QUEUED
  ACTIVE
  PAUSED
  DONE
}

model Resource {
  id         String         @id @default(cuid())
  userId     String
  title      String
  source     String? // domain or author
  url        String?
  coverUrl   String?
  kind       ResourceKind   @default(READING)
  status     ResourceStatus @default(QUEUED)
  progress   Int            @default(0) // 0-100
  takeaways  String         @default("")
  nowReading Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ───────────────────────────────────────────────────────────────────────────
// Spaced repetition (SM-2)
// ───────────────────────────────────────────────────────────────────────────

model ReviewCard {
  id           String   @id @default(cuid())
  userId       String
  front        String
  back         String
  noteId       String?
  ease         Float    @default(2.5)
  interval     Int      @default(0) // days
  repetitions  Int      @default(0)
  dueAt        DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueAt])
}

// ───────────────────────────────────────────────────────────────────────────
// Focus timer
// ───────────────────────────────────────────────────────────────────────────

enum FocusKind {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

model FocusSession {
  id          String    @id @default(cuid())
  userId      String
  kind        FocusKind @default(FOCUS)
  durationSec Int
  completed   Boolean   @default(true)
  startedAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

// ───────────────────────────────────────────────────────────────────────────
// Uploaded files (PDF/DOCX/PPTX). Stored in DB so the app stays portable —
// works locally with SQLite and on Vercel with Postgres without object storage.
// ───────────────────────────────────────────────────────────────────────────

model Upload {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
