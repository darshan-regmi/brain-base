# ─── Database ────────────────────────────────────────────────────────────
# Local dev: SQLite (default).
DATABASE_URL="file:./prisma/dev.db"
# Production (Vercel + Postgres): set DATABASE_URL to your Postgres connection
# string and change `provider = "postgresql"` in prisma/schema.prisma before
# the first `prisma generate`. Neon, Supabase, and Vercel Postgres all work.
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
AUTH_SECRET=replace-with-a-32-byte-hex-string
AUTH_URL=http://localhost:3000
# In production, set AUTH_URL to your deployed origin (e.g. https://your-app.vercel.app).

# ─── OAuth providers (optional) ──────────────────────────────────────────
# Leave blank to disable; the credentials provider works without them.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
